# Neon Postgres ? pooled connection string from the Neon dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# OpenAI ? API key from https://platform.openai.com/api-keys (API usage is billed separately from ChatGPT Plus)
OPENAI_API_KEY="sk-..."

# Optional ? default gpt-4o for suggest flow. Use gpt-4o-mini for cheaper calls.
# OPENAI_SUGGESTION_MODEL=gpt-4o-mini

# Optional ? model for SEO/discovery brief generation. Falls back to OPENAI_SUGGESTION_MODEL/default.
# OPENAI_SEO_MODEL=gpt-4o-mini

# Upstash Redis (optional) ? REST URL + token from https://console.upstash.com
# Leave blank or delete these two lines until you have a real database; otherwise the app skips rate limiting.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional ? only for `npm run github:publish` (creates repo + push). Do not commit real tokens.
# GITHUB_TOKEN=github_pat_... or ghp_...
# GITHUB_OWNER=your-github-username
# GITHUB_REPO=elfster-ai-prototype
